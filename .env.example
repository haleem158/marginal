# ─── 0G Chain Mainnet ─────────────────────────────────────────────────────────
OG_RPC_URL=https://evmrpc.0g.ai
NEXT_PUBLIC_CHAIN_ID=16661
NEXT_PUBLIC_RPC_URL=https://evmrpc.0g.ai
NEXT_PUBLIC_OG_EXPLORER=https://chainscan.0g.ai

# ─── Deployed Contract Addresses (mainnet — already live) ─────────────────────
AUCTION_HOUSE_ADDRESS=0x17758a3324B65FEbDccDdf3659A4eDD5487d861A
STAKE_VAULT_ADDRESS=0xe2119bf943999647A8C5EA025Ea13C98c020A39F
MARGINAL_NFT_ADDRESS=0xa17931723B7fAED34F8532a95F8b62DD27a06102
NEXT_PUBLIC_AUCTION_HOUSE_ADDRESS=0x17758a3324B65FEbDccDdf3659A4eDD5487d861A
NEXT_PUBLIC_STAKE_VAULT_ADDRESS=0xe2119bf943999647A8C5EA025Ea13C98c020A39F
NEXT_PUBLIC_MARGINAL_NFT_ADDRESS=0xa17931723B7fAED34F8532a95F8b62DD27a06102

# ─── Agent Wallets (fund each with ~0.1 A0GI for gas) ─────────────────────────
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_KEY
AUCTIONEER_PRIVATE_KEY=0xYOUR_AUCTIONEER_KEY
EXECUTOR_PRIVATE_KEY=0xYOUR_EXECUTOR_KEY
AUDITOR_PRIVATE_KEY=0xYOUR_AUDITOR_KEY

# ─── 0G Compute / OpenAI-compatible inference ─────────────────────────────────
# Use your 0G Compute key, or any OpenAI-compatible provider (Groq, etc.)
OG_COMPUTE_API_KEY=your_api_key_here
OG_COMPUTE_BASE_URL=https://api.groq.com/openai/v1
OG_COMPUTE_MODEL=llama-3.3-70b-versatile

# ─── 0G Storage ───────────────────────────────────────────────────────────────
# Falls back to Memory Indexer (localhost:8001) if unreachable
OG_STORAGE_NODE_URL=https://storage.0g.ai
OG_KV_BUCKET=marginal-agent-state
OG_LOG_STREAM_ID=marginal-task-log

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AUCTIONEER_URL=http://localhost:8000
NEXT_PUBLIC_INDEXER_URL=http://localhost:8001

# ─── Security ─────────────────────────────────────────────────────────────────
# Random string — prevents unauthenticated score injection via /tasks/{id}/settle
SETTLE_API_KEY=generate_with_openssl_rand_hex_32

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

AUDITOR_PRIVATE_KEY=0xAUDITOR_WALLET_KEY
AUCTIONEER_PRIVATE_KEY=0xAUCTIONEER_WALLET_KEY

# ─── Agent Config ─────────────────────────────────────────────────────────────
AGENT_ID=executor-001
MIN_PROFIT_MARGIN=0.05
MAX_BID_MULTIPLIER=1.3
AUDITOR_COUNT=3

# ─── API Security ─────────────────────────────────────────────────────────────
# Shared secret between Auctioneer and Auditor — prevents unauthenticated score injection.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SETTLE_API_KEY=CHANGE_ME_TO_A_RANDOM_SECRET

# Bind host for Auctioneer (:8000) and Memory Indexer (:8001)
# Use 127.0.0.1 (default) for local dev. Use 0.0.0.0 only behind a reverse proxy with auth.
AGENT_BIND_HOST=127.0.0.1

# Set to true ONLY if you want the guard to allow tasks when 0G Compute is unavailable.
# Default is false (fail-closed — safer).
GUARD_FAIL_OPEN=false

# Comma-separated origins the Auctioneer API allows for browser CORS requests.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=16600
NEXT_PUBLIC_AUCTION_HOUSE_ADDRESS=0x
NEXT_PUBLIC_STAKE_VAULT_ADDRESS=0x
NEXT_PUBLIC_MARGINAL_NFT_ADDRESS=0x
NEXT_PUBLIC_OG_EXPLORER=https://chainscan-galileo.0g.ai
NEXT_PUBLIC_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_AUCTIONEER_URL=http://localhost:8000
NEXT_PUBLIC_INDEXER_URL=http://localhost:8001
