# ─── Deployer ─────────────────────────────────────────────────────────────────
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# ─── 0G Network RPCs ──────────────────────────────────────────────────────────
OG_TESTNET_RPC=https://evmrpc-testnet.0g.ai
OG_MAINNET_RPC=https://evmrpc.0g.ai
OG_EXPLORER_API_KEY=your_explorer_api_key

# ─── Deployed Contract Addresses (filled after deploy) ────────────────────────
AUCTION_HOUSE_ADDRESS=0x
STAKE_VAULT_ADDRESS=0x
MARGINAL_NFT_ADDRESS=0x

# ─── 0G Compute ───────────────────────────────────────────────────────────────
OG_COMPUTE_API_KEY=your_0g_compute_api_key
OG_COMPUTE_BASE_URL=https://api.0g.ai/v1
OG_COMPUTE_MODEL=qwen3.6-plus

# ─── 0G Storage ───────────────────────────────────────────────────────────────
OG_STORAGE_NODE_URL=https://storage.0g.ai
OG_KV_BUCKET=marginal-agent-state
OG_LOG_STREAM_ID=marginal-task-log

# ─── Agent Wallets (one per executor instance) ────────────────────────────────
EXECUTOR_PRIVATE_KEY=0xEXECUTOR_WALLET_KEY
AUDITOR_PRIVATE_KEY=0xAUDITOR_WALLET_KEY
AUCTIONEER_PRIVATE_KEY=0xAUCTIONEER_WALLET_KEY

# ─── Agent Config ─────────────────────────────────────────────────────────────
AGENT_ID=executor-001
MIN_PROFIT_MARGIN=0.05
MAX_BID_MULTIPLIER=1.3
AUDITOR_COUNT=3

# ─── API Security ─────────────────────────────────────────────────────────────
# Shared secret between Auctioneer and Auditor — prevents unauthenticated score injection.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SETTLE_API_KEY=CHANGE_ME_TO_A_RANDOM_SECRET

# Bind host for Auctioneer (:8000) and Memory Indexer (:8001)
# Use 127.0.0.1 (default) for local dev. Use 0.0.0.0 only behind a reverse proxy with auth.
AGENT_BIND_HOST=127.0.0.1

# Set to true ONLY if you want the guard to allow tasks when 0G Compute is unavailable.
# Default is false (fail-closed — safer).
GUARD_FAIL_OPEN=false

# Comma-separated origins the Auctioneer API allows for browser CORS requests.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CHAIN_ID=16600
NEXT_PUBLIC_AUCTION_HOUSE_ADDRESS=0x
NEXT_PUBLIC_STAKE_VAULT_ADDRESS=0x
NEXT_PUBLIC_MARGINAL_NFT_ADDRESS=0x
NEXT_PUBLIC_OG_EXPLORER=https://chainscan-galileo.0g.ai
NEXT_PUBLIC_RPC_URL=https://evmrpc-testnet.0g.ai
NEXT_PUBLIC_AUCTIONEER_URL=http://localhost:8000
NEXT_PUBLIC_INDEXER_URL=http://localhost:8001
